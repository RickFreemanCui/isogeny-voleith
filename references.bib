@incollection{baumPubliclyVerifiableZeroKnowledge2023,
  title = {Publicly {{Verifiable Zero-Knowledge}} and {{Post-Quantum Signatures}} from {{VOLE-in-the-Head}}},
  booktitle = {Advances in {{Cryptology}} -- {{CRYPTO}} 2023},
  author = {Baum, Carsten and Braun, Lennart and De Saint Guilhem, Cyprien Delpech and Kloo{\ss}, Michael and Orsini, Emmanuela and Roy, Lawrence and Scholl, Peter},
  editor = {Handschuh, Helena and Lysyanskaya, Anna},
  year = 2023,
  volume = {14085},
  pages = {581--615},
  publisher = {Springer Nature Switzerland},
  address = {Cham},
  doi = {10.1007/978-3-031-38554-4_19},
  urldate = {2023-11-28},
  abstract = {We present a new method for transforming zero-knowledge protocols in the designated verifier setting into public-coin protocols, which can be made non-interactive and publicly verifiable. Our transformation applies to a large class of ZK protocols based on oblivious transfer. In particular, we show that it can be applied to recent, fast protocols based on vector oblivious linear evaluation (VOLE), with a technique we call VOLE-in-the-head, upgrading these protocols to support public verifiability. Our resulting ZK protocols have linear proof size, and are simpler, smaller and faster than related approaches based on MPC-in-the-head.},
  isbn = {978-3-031-38553-7 978-3-031-38554-4},
  langid = {english},
